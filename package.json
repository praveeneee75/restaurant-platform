{
  "name": "restaurant-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Restaurant SaaS and local POS platform",
  "scripts": {
    "branding:generate": "powershell -ExecutionPolicy Bypass -File scripts/generate-kmaster-branding.ps1",
    "start:all": "node scripts/start-all.js",
    "start:pos": "node scripts/start-all.js pos",
    "start:saas": "node scripts/start-all.js saas",
    "start:mobile": "node scripts/start-all.js mobile",
    "stop:all": "node scripts/stop-service.js all",
    "stop:pos": "node scripts/stop-service.js pos",
    "stop:saas": "node scripts/stop-service.js saas",
    "stop:mobile": "node scripts/stop-service.js mobile",
    "build:pos:win": "npm --prefix pos-app run dist:win",
    "build:pos:mac": "npm --prefix pos-app run dist:mac",
    "build:pos:linux": "npm --prefix pos-app run dist:linux",
    "build:pos:win:publish": "npm run build:pos:win && npm run publish:pos:installers",
    "build:pos:mac:publish": "npm run build:pos:mac && npm run publish:pos:installers",
    "build:pos:linux:publish": "npm run build:pos:linux && npm run publish:pos:installers",
    "publish:pos:installers": "node scripts/publish-pos-installers.js",
    "check:production-env": "node scripts/validate-deployment-env.js production",
    "setup:palmsy": "npm --prefix saas-backend run migrate && node scripts/setup-palmsy.js",
    "test": "node tests/smoke-commercial-readiness.js",
    "test:pos": "node tests/pos-smoke.js",
    "test:pos:regression": "node tests/pos-regression.js",
    "test:pos:matrix": "node tests/pos-100-matrix.js",
    "test:admin:regression": "node tests/admin-regression.js",
    "test:billing:regression": "node tests/billing-controls-regression.js",
    "test:production:urls": "node tests/production-url-regression.js",
    "test:reported-issues": "node tests/reported-issues-regression.js",
    "test:saas": "node tests/saas-smoke.js"
    ,"test:owner-control": "node tests/owner-remote-control-regression.js"
    ,"test:qr-approval": "node tests/qr-approval-regression.js"
    ,"test:qr-kds-owner": "node tests/qr-kds-owner-hardening-regression.js"
    ,"test:latest-feedback": "node tests/latest-production-feedback-regression.js"
  }
}
