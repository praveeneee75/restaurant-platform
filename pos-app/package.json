{
  "name": "pos-app",
  "version": "1.0.45",
  "description": "Restaurant POS local backend",
  "main": "electron/main.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "node backend/server.js",
    "desktop": "electron electron/main.js",
    "pre-dist:win": "electron-rebuild --force --which-module better-sqlite3 --version 42.5.0 && electron-rebuild --force --which-module bcrypt --version 42.5.0",
    "post-dist:win": "npm rebuild better-sqlite3 bcrypt",
    "dist:win": "electron-builder --win nsis",
    "dist:mac": "electron-builder --mac dmg",
    "dist:linux": "electron-builder --linux AppImage deb",
    "dist:all": "electron-builder --win nsis --mac dmg --linux AppImage deb",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "body-parser": "^2.2.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fs-extra": "^11.3.3"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.kmaster.pos",
    "productName": "K'Master POS",
    "directories": {
      "output": "dist-installers"
    },
    "files": [
      "backend/**/*",
      "electron/**/*",
      "package.json",
      "!backend/**/*.log",
      "!data/**/*",
      "!backups/**/*",
      "!updates/staging/**/*",
      "!*.db",
      "!.env"
    ],
    "asar": true,
    "npmRebuild": false,
    "buildDependenciesFromSource": true,
    "asarUnpack": [
      "node_modules/bcrypt/**/*",
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis",
      "signAndEditExecutable": false,
      "artifactName": "KMaster-POS-Setup-${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "artifactName": "KMaster-POS-${version}.${ext}"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "KMaster-POS-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
